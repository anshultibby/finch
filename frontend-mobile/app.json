{
  "expo": {
    "name": "Finch",
    "slug": "finch",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "finch",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#fafaf9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.finch.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Finch to access your camera to take photos for chat attachments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#fafaf9"
      },
      "package": "com.finch.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
